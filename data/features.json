    {
      "name": "モデル/API",
      "description": "アプリやワークフローからAIモデルを呼び出す基本機能。",
      "watchPoint": "モデル名、提供状態、価格、レート制限、コンテキスト長を確認する。"
    },
    {
      "name": "エージェント",
      "description": "複数ステップの作業、ツール呼び出し、ファイル操作などをAIに任せる機能。",
      "watchPoint": "権限、実行環境、監査ログ、失敗時の巻き戻しを確認する。"
    },
    {
      "name": "コード支援",
      "description": "補完、レビュー、Issue整理、リポジトリ作業など開発作業を支援する機能。",
      "watchPoint": "対象IDE、リポジトリアクセス、組織設定、プレビュー制約を確認する。"
    },
    {
      "name": "音声",
      "description": "音声入力、音声出力、リアルタイム会話、文字起こしに関係する機能。",
      "watchPoint": "レイテンシ、対応言語、録音データの扱い、ブラウザ対応を確認する。"
    },
    {
      "name": "画像/動画",
      "description": "画像生成、画像理解、動画生成、マルチモーダル入力に関係する機能。",
      "watchPoint": "生成物の利用条件、解像度、透かし、セーフティ制約を確認する。"
    },
    {
      "name": "ツール実行/MCP",
      "description": "外部ツール、社内API、MCPサーバーなどとAIを接続する機能。",
      "watchPoint": "認可境界、スコープ、秘密情報の扱い、実行ログを確認する。"
    },
    {
      "name": "管理/セキュリティ",
      "description": "組織管理、監査、データ保持、セキュリティアドバイザリに関係する機能。",
      "watchPoint": "SSO、監査ログ、データ保持、依存パッケージの安全性を確認する。"
    }
  ],
